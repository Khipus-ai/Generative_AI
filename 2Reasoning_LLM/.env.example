# Endpoint Azure OpenAI / Microsoft Foundry Models v1
# Formatos válidos:
#   https://<resource>.services.ai.azure.com/openai/v1
#   https://<resource>.openai.azure.com/openai/v1
AZURE_ENDPOINT=https://<tu-recurso>.services.ai.azure.com/openai/v1

# IMPORTANTE: nunca subas tu clave real a GitHub ni la muestres en pantalla.
AZURE_KEY=<tu-clave-regenerada>

# Debe ser el nombre exacto del deployment configurado en Azure/Foundry.
AZURE_DEPLOYMENT=DeepSeek-V3.2

REQUEST_TIMEOUT_SECONDS=60
FLASK_DEBUG=0
